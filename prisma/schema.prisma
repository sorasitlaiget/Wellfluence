generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BRAND
  INFLUENCER
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContentSubmissionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SocialPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  FACEBOOK
  OTHER
}

enum TransactionType {
  CAMPAIGN_PAYMENT_IN // Brand pays platform
  INFLUENCER_PAYOUT   // Platform pays influencer
  PLATFORM_COMMISSION // Commission taken by platform
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String
  role            UserRole
  isEmailVerified Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  brandProfile      BrandProfile?
  influencerProfile InfluencerProfile?

  @@index([email])
  @@index([role])
}

model BrandProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  companyName    String
  description    String?
  industry       String?
  logoUrl        String?
  website        String?
  contactEmail   String?
  targetAudience Json?     // JSONB equivalent in Prisma for flexible data
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([userId])
  @@index([companyName])
}

model InfluencerProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  bio             String?
  profilePictureUrl String?
  portfolioUrl    String?
  rateCardUrl     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  niches               Niche[]               @relation("InfluencerNiches")
  socialAccounts       SocialAccount[]
  campaignApplications CampaignApplication[]
  availability         Json?                 // For AvailabilityCalendar for now, e.g., { "monday": ["9-12", "14-17"] }
  followerCount        Int?
  engagementRate       Float?                // Typically a percentage, e.g., 2.5 for 2.5%
  demographics         Json?                 // For demographics, e.g., { "ageGroup": "18-24", "gender": "female", "location": "Bangkok" }

  @@index([userId])
  @@index([followerCount])
  @@index([engagementRate])
}

model Niche {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  influencers InfluencerProfile[] @relation("InfluencerNiches")
  campaigns   Campaign[]          @relation("CampaignNiches")

  @@index([name])
}

model SocialAccount {
  id                  String         @id @default(uuid())
  influencerProfileId String
  platform            SocialPlatform
  platformId          String         @unique // e.g., Instagram user ID, unique per platform
  profileUrl          String?
  accessToken         String?        // Stored encrypted in a real app, placeholder for Sprint 1
  refreshToken        String?        // Stored encrypted, placeholder for Sprint 1
  followersCount      Int?
  engagementRate      Float?
  lastSyncedAt        DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  influencerProfile InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)

  @@index([influencerProfileId])
  @@index([platform])
  @@index([platformId])
}

model Campaign {
  id             String        @id @default(uuid())
  brandProfileId String
  title          String
  description    String?
  objective      String?
  budget         Float
  startDate      DateTime
  endDate        DateTime
  status         CampaignStatus @default(DRAFT)
  deliverables   Json?         // e.g., [{ "type": "post", "count": 1, "platform": "INSTAGRAM" }]
  targetFollowerCountMin Int?
  targetFollowerCountMax Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  brandProfile BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  niches       Niche[]      @relation("CampaignNiches")
  applications CampaignApplication[]
  transactions Transaction[]

  @@index([brandProfileId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model CampaignApplication {
  id                   String                  @id @default(uuid())
  campaignId           String
  influencerProfileId  String
  status               ApplicationStatus       @default(APPLIED)
  proposedRate         Float?                  // Rate proposed by influencer for this specific campaign
  message              String?                 // Cover letter/message from influencer
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  campaign            Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencerProfile   InfluencerProfile     @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)
  contentSubmissions  ContentSubmission[]
  transactions        Transaction[]

  @@unique([campaignId, influencerProfileId]) // An influencer can only apply once per campaign
  @@index([campaignId])
  @@index([influencerProfileId])
  @@index([status])
}

model ContentSubmission {
  id                     String                    @id @default(uuid())
  campaignApplicationId  String
  contentUrl             String                    // URL to the submitted content (e.g., S3 URL)
  status                 ContentSubmissionStatus   @default(DRAFT)
  feedback               String?
  submittedAt            DateTime                  @default(now())
  approvedAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  campaignApplication CampaignApplication @relation(fields: [campaignApplicationId], references: [id], onDelete: Cascade)

  @@index([campaignApplicationId])
  @@index([status])
}

model Transaction {
  id                     String            @id @default(uuid())
  campaignId             String?           // For overall campaign payments (e.g., brand to platform)
  campaignApplicationId  String?           // For influencer specific payouts
  type                   TransactionType
  amount                 Float
  currency               String            @default("THB") // Assuming THB as per PRD locale
  status                 TransactionStatus @default(PENDING)
  platformCommissionAmount Float?          // Amount platform takes as commission
  paymentGatewayRef      String?           // Reference ID from Omise/Stripe for external transaction
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  campaign            Campaign?           @relation(fields: [campaignId], references: [id])
  campaignApplication CampaignApplication? @relation(fields: [campaignApplicationId], references: [id])

  @@index([campaignId])
  @@index([campaignApplicationId])
  @@index([type])
  @@index([status])
}